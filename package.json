{
  "name": "mcp-code-mode",
  "version": "0.0.1",
  "description": "Wrap a Node/Bun MCP server with fail-closed search and sandboxed multi-tool execution.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "code-mode",
    "sandbox",
    "agent",
    "llm",
    "quickjs"
  ],
  "license": "MIT",
  "author": "Jordan Coeyman (@acoyfellow)",
  "homepage": "https://github.com/acoyfellow/mcp-code-mode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acoyfellow/mcp-code-mode.git"
  },
  "bugs": {
    "url": "https://github.com/acoyfellow/mcp-code-mode/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js"
    },
    "./search": {
      "types": "./dist/search.d.ts",
      "import": "./dist/search.js"
    },
    "./sandbox/worker": {
      "types": "./dist/sandbox/worker.d.ts",
      "import": "./dist/sandbox/worker.js"
    },
    "./sandbox/quickjs": {
      "types": "./dist/sandbox/quickjs.d.ts",
      "import": "./dist/sandbox/quickjs.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.test.json",
    "check:worker": "node scripts/check-worker.mjs",
    "test": "bun test",
    "test:node": "node examples/node-smoke.mjs",
    "prove:consumer": "node scripts/prove-packed-consumer.mjs",
    "prove:firestore": "node scripts/prove-firestore-consumer.mjs",
    "verify": "bun run check && bun run check:worker && bun test && bun run build && bun run test:node && bun run prove:consumer && bun run prove:firestore && npm pack --dry-run",
    "demo": "bun examples/echo-server/index.ts",
    "stress": "bun run build && node bench/stress.mjs",
    "play": "npx --yes @modelcontextprotocol/inspector@0.22.0 bun examples/mcp-server/index.ts",
    "prepublishOnly": "bun run verify"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": false
    }
  },
  "optionalDependencies": {
    "@jitl/quickjs-ng-wasmfile-release-sync": "^0.32.0",
    "@sebastianwessel/quickjs": "^3.1.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.19.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
